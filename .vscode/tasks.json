{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install demo_engine and plugins (Debug)",
      "type": "shell",
      "command": "cmake --build --preset vs2022-x64-install --target demo_engine renderd3d11 rendervulkan systemwin32 --config Debug",
      "options": {
        "shell": {
          "executable": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe",
          "args": [
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-Command"
          ]
        }
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "build"
    },
    {
      "label": "Install create utilities (Debug)",
