    {
      "label": "CMake Install (Debug)",
      "type": "shell",
      "command": "cmake --install build --config Debug",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "Build All (Debug)",
      "type": "shell",
      "command": "cmake --build build --config Debug",
      "problemMatcher": ["$msCompile"],
      "group": "build"
    },
    {
      "label": "Install All (Debug)",
      "type": "shell",
      "command": "cmake --install build --config Debug",
